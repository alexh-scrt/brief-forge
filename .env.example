# ──────────────────────────────────────────────────────────────────────────────
# Brief Forge — Environment Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values before running the app.
#
#   cp .env.example .env
#
# The `.env` file is loaded automatically by python-dotenv when the app starts.
# Never commit your real `.env` file — it is already listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Your OpenAI API key.  Obtain one at https://platform.openai.com/api-keys
# Required — the application will raise a RuntimeError on startup if missing.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI model to use for brief generation.
# Recommended: gpt-4o (best quality) or gpt-4o-mini (faster / cheaper).
# Defaults to "gpt-4o" when not set.
OPENAI_MODEL=gpt-4o

# Maximum tokens the model may generate per request.
# 2048 is a safe default; increase if briefs are being truncated.
OPENAI_MAX_TOKENS=2048

# Temperature controls creativity vs. determinism (0.0 – 2.0).
# 0.7 gives a good balance of variety and coherence for design briefs.
OPENAI_TEMPERATURE=0.7


# ── Flask ─────────────────────────────────────────────────────────────────────
# A long, random string used to sign session cookies and CSRF tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Required — do NOT use the placeholder value in production.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Flask environment: "development" enables debug mode and the interactive
# debugger.  Set to "production" when deploying publicly.
FLASK_ENV=development

# Host and port the development server binds to.
# Change to 0.0.0.0 to accept connections from other machines on the network.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
